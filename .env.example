# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Database (Supabase)
# Pooled connection — use port 6543 with ?pgbouncer=true for runtime queries

# Done Start 

DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — use port 5432 for Prisma migrations (npx prisma db push)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

# Done End





# Done Start 

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Done End







# OAuth (configured in Supabase dashboard)
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers





# Done Start 
# AI
GOOGLE_AI_API_KEY="your-google-ai-api-key"
# Done End




# Queue (Upstash Redis)
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"






# Billing (Lemon Squeezy)
# API key from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY="your-lemon-squeezy-api-key"
# Webhook secret — set when creating webhook in LS dashboard
LEMONSQUEEZY_WEBHOOK_SECRET="your-webhook-secret-phrase"
# Your store slug from https://app.lemonsqueezy.com/settings
NEXT_PUBLIC_LEMONSQUEEZY_STORE_URL="https://your-store.lemonsqueezy.com"
# Variant IDs from your product's variants in the LS dashboard
NEXT_PUBLIC_LEMONSQUEEZY_PRO_VARIANT_ID="your-pro-variant-id"
NEXT_PUBLIC_LEMONSQUEEZY_SCALE_VARIANT_ID="your-scale-variant-id"






# Cron Security
# Any random string — used to authenticate Vercel Cron requests
CRON_SECRET="N16E7bzOqYkDng2GcBpvxuMQAmVUPl8H"

# Analytics & Error Tracking
# Create project at https://sentry.io → Next.js → copy DSN
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project-id"
# Create project at https://posthog.com → copy API key
NEXT_PUBLIC_POSTHOG_KEY="phc_your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# App
# Your production domain (used for SEO metadata base URL)
NEXT_PUBLIC_APP_URL="https://your-domain.com"
